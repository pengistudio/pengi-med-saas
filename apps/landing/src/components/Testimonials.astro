---
const testimonials = [
    {
        name: "Dra. Carmen Vásquez",
        role: "Médico General",
        location: "Quito",
        avatar: "CV",
        gradient: "linear-gradient(135deg, oklch(62% 0.14 280), oklch(72% 0.1 220))",
        quote: "Antes tardaba horas en facturar al SRI. Con Gentoo lo hago en segundos. Increíblemente intuitivo y soporte muy rápido.",
        stars: 5,
    },
    {
        name: "Dr. Roberto Andrade",
        role: "Traumatólogo",
        location: "Guayaquil",
        avatar: "RA",
        gradient: "linear-gradient(135deg, oklch(59.929% 0.0998 185.282), oklch(65% 0.12 160))",
        quote: "El control de expedientes con ICD-11 es brillante. La agenda digital ha reducido las citas perdidas casi a cero.",
        stars: 5,
    },
    {
        name: "Dra. Patricia Mora",
        role: "Pediatra",
        location: "Cuenca",
        avatar: "PM",
        gradient: "linear-gradient(135deg, oklch(70% 0.12 55), oklch(72% 0.1 30))",
        quote: "Gentoo simplificó completamente nuestra gestión. Desde las recetas hasta la facturación, todo en una plataforma.",
        stars: 5,
    },
];
---

<section id="testimonials" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <div class="glass inline-flex items-center gap-2 px-4 py-2 rounded-full text-primary text-sm font-semibold mb-6">
                Testimonios
            </div>
            <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-text mb-4">
                Lo que dicen nuestros médicos
            </h2>
            <p class="text-lg text-text-muted">
                Más de 500 profesionales de la salud en Ecuador confían en Gentoo.
            </p>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
            {testimonials.map((t) => (
                <div class="group glass-card rounded-3xl p-8 flex flex-col gap-6 hover:scale-[1.02] transition-all duration-300 overflow-hidden relative">
                    <!-- Corner gradient -->
                    <div class="absolute top-0 right-0 w-32 h-32 rounded-full blur-3xl opacity-30 group-hover:opacity-50 transition-opacity duration-500"
                        style={`background: ${t.gradient};`}>
                    </div>

                    <div class="relative z-10 flex flex-col gap-6 flex-1">
                        <!-- Stars -->
                        <div class="flex gap-1">
                            {Array.from({ length: t.stars }).map(() => (
                                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                            ))}
                        </div>

                        <blockquote class="text-text-muted leading-relaxed flex-1 italic">
                            "{t.quote}"
                        </blockquote>

                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-full flex items-center justify-center text-white font-bold text-sm shrink-0"
                                style={`background: ${t.gradient};`}>
                                {t.avatar}
                            </div>
                            <div>
                                <p class="font-display font-bold text-text text-sm">{t.name}</p>
                                <p class="text-xs text-text-muted">{t.role} · {t.location}</p>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
