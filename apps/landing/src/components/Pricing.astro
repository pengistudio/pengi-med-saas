---
const plans = [
    {
        name: "Básico",
        price: "$29",
        period: "/mes",
        description: "Para consultorios independientes que quieren digitalizarse.",
        features: [
            "Hasta 500 pacientes",
            "Agenda de citas",
            "Expedientes clínicos con ICD-11",
            "Recetas médicas en PDF",
            "Hasta 3 usuarios / 1 consultorio",
            "Soporte por correo",
        ],
        cta: "Solicitar acceso",
        highlighted: false,
        accentColor: "oklch(62% 0.14 280)",
        ctaStyle: "background: oklch(100% 0 0 / 70%); border: 1px solid oklch(100% 0 0 / 60%); color: var(--color-text);",
        showFreeTrial: true,
    },
    {
        name: "Profesional",
        price: "$59",
        period: "/mes",
        description: "Para clínicas en crecimiento con necesidades avanzadas.",
        features: [
            "Pacientes ilimitados",
            "Todo lo del plan Básico",
            "Facturación electrónica SRI",
            "Sala de espera digital",
            "Plantillas personalizadas de recetas",
            "Hasta 5 usuarios",
            "Soporte prioritario",
        ],
        cta: "Solicitar acceso",
        highlighted: true,
        accentColor: "oklch(59.929% 0.0998 185.282)",
        ctaStyle: "background: linear-gradient(135deg, oklch(59.929% 0.0998 185.282), oklch(62% 0.14 280)); color: oklch(0.98 0.01 181); box-shadow: 0 4px 16px oklch(59.929% 0.0998 185.282 / 30%);",
        showFreeTrial: true,
    },
    {
        name: "Empresarial",
        price: "A medida",
        period: "",
        description: "Para instituciones con múltiples consultorios y equipos.",
        features: [
            "Todo lo del plan Profesional",
            "Usuarios y consultorios ilimitados",
            "Roles y permisos personalizados",
            "Onboarding dedicado",
            "SLA garantizado",
            "Soporte 24/7",
        ],
        cta: "Contactar ventas",
        highlighted: false,
        accentColor: "oklch(65% 0.12 160)",
        ctaStyle: "background: oklch(100% 0 0 / 70%); border: 1px solid oklch(100% 0 0 / 60%); color: var(--color-text);",
        showFreeTrial: false,
    },
];
---

<section id="pricing" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <div class="glass inline-flex items-center gap-2 px-4 py-2 rounded-full text-primary text-sm font-semibold mb-6">
                Planes
            </div>
            <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-text mb-4">
                Un plan para cada necesidad
            </h2>
            <p class="text-lg text-text-muted">
                Sin contratos anuales obligatorios. Cambia o cancela cuando quieras.
            </p>
        </div>

        <!-- pt-5: badge room above; items-stretch: equal heights -->
        <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto pt-5 items-stretch">
            {plans.map((plan) => (
                <div class="relative flex flex-col">

                    {/* Badge centered on top border */}
                    {plan.highlighted && (
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20">
                            <span class="block px-4 py-1.5 rounded-full text-xs font-bold text-primary-foreground uppercase tracking-wider whitespace-nowrap"
                                style="background: linear-gradient(135deg, oklch(59.929% 0.0998 185.282), oklch(62% 0.14 280)); box-shadow: 0 4px 16px oklch(59.929% 0.0998 185.282 / 40%);">
                                ⭐ Más Popular
                            </span>
                        </div>
                    )}

                    {/* Highlighted: gradient-border wrapper */}
                    {plan.highlighted && (
                        <div class="flex-1 flex flex-col"
                            style="padding: 2px; border-radius: 1.75rem; background: linear-gradient(135deg, oklch(59.929% 0.0998 185.282), oklch(62% 0.14 280)); box-shadow: 0 24px 64px oklch(59.929% 0.0998 185.282 / 20%);">
                            <div class="flex-1 flex flex-col p-8 relative overflow-hidden"
                                style="border-radius: calc(1.75rem - 2px); background: oklch(98% 0.005 185 / 92%); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);">
                                <div class="absolute top-0 right-0 w-48 h-48 rounded-full blur-3xl pointer-events-none opacity-20"
                                    style="background: linear-gradient(135deg, oklch(72% 0.1 183), oklch(65% 0.12 280));"></div>
                                <div class="relative z-10 flex flex-col flex-1">
                                    <div class="mb-5">
                                        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                                            style={`background: ${plan.accentColor}25;`}>
                                            <div class="w-4 h-4 rounded-full" style={`background: ${plan.accentColor};`}></div>
                                        </div>
                                        <h3 class="font-display text-xl font-bold text-text mb-1">{plan.name}</h3>
                                        <p class="text-sm text-text-muted">{plan.description}</p>
                                    </div>
                                    <div class="flex items-baseline gap-1 mb-7">
                                        <span class="font-display text-5xl font-bold text-text">{plan.price}</span>
                                        {plan.period && <span class="text-text-muted font-medium">{plan.period}</span>}
                                    </div>
                                    <ul class="flex flex-col gap-2.5 mb-7 flex-1">
                                        {plan.features.map((f) => (
                                            <li class="flex items-start gap-2.5 text-sm text-text-muted">
                                                <svg class="w-4 h-4 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" style={`color: ${plan.accentColor};`}>
                                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                                </svg>
                                                {f}
                                            </li>
                                        ))}
                                    </ul>
                                    <div class="mt-auto">
                                        <a href="mailto:pengiservicios@gmail.com"
                                            class="inline-flex items-center justify-center w-full py-3.5 rounded-2xl text-sm font-bold transition-all duration-300 hover:-translate-y-0.5"
                                            style={plan.ctaStyle}>
                                            {plan.cta}
                                        </a>
                                        {plan.showFreeTrial && (
                                            <p class="text-xs text-center text-text-muted mt-2.5">14 días gratis · Sin tarjeta de crédito</p>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* Regular card */}
                    {!plan.highlighted && (
                        <div class="flex-1 flex flex-col glass-card rounded-3xl p-8 relative overflow-hidden hover:scale-[1.01] transition-all duration-300">
                            <div class="absolute top-0 right-0 w-40 h-40 rounded-full blur-3xl pointer-events-none opacity-20"
                                style={`background: ${plan.accentColor};`}></div>
                            <div class="relative z-10 flex flex-col flex-1">
                                <div class="mb-5">
                                    <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                                        style={`background: ${plan.accentColor}25;`}>
                                        <div class="w-4 h-4 rounded-full" style={`background: ${plan.accentColor};`}></div>
                                    </div>
                                    <h3 class="font-display text-xl font-bold text-text mb-1">{plan.name}</h3>
                                    <p class="text-sm text-text-muted">{plan.description}</p>
                                </div>
                                <div class="flex items-baseline gap-1 mb-7">
                                    <span class="font-display text-5xl font-bold text-text">{plan.price}</span>
                                    {plan.period && <span class="text-text-muted font-medium">{plan.period}</span>}
                                </div>
                                <ul class="flex flex-col gap-2.5 mb-7 flex-1">
                                    {plan.features.map((f) => (
                                        <li class="flex items-start gap-2.5 text-sm text-text-muted">
                                            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" style={`color: ${plan.accentColor};`}>
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                            </svg>
                                            {f}
                                        </li>
                                    ))}
                                </ul>
                                <div class="mt-auto">
                                    <a href="mailto:pengiservicios@gmail.com"
                                        class="inline-flex items-center justify-center w-full py-3.5 rounded-2xl text-sm font-bold transition-all duration-300 hover:-translate-y-0.5"
                                        style={plan.ctaStyle}>
                                        {plan.cta}
                                    </a>
                                    {plan.showFreeTrial && (
                                        <p class="text-xs text-center text-text-muted mt-2.5">14 días gratis · Sin tarjeta de crédito</p>
                                    )}
                                </div>
                            </div>
                        </div>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>
