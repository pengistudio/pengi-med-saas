---
const features = [
	{
		icon: "patients",
		title: "Gestión de Pacientes",
		description:
			"Registro completo con historial médico, datos demográficos, clasificación por criticidad y sala de espera digital en tiempo real.",
	},
	{
		icon: "calendar",
		title: "Agenda de Citas",
		description:
			"Calendario para programar, reprogramar y gestionar citas. Visualización diaria y semanal con estados por consulta.",
	},
	{
		icon: "records",
		title: "Expedientes Clínicos",
		description:
			"Expedientes digitales con diagnósticos codificados en ICD-11, evoluciones, antecedentes y archivos adjuntos.",
	},
	{
		icon: "prescription",
		title: "Recetas Médicas",
		description:
			"Genera recetas en PDF con tu membrete personalizado. Sube tu propio template HTML y descárgalas desde cualquier dispositivo.",
	},
	{
		icon: "billing",
		title: "Facturación Electrónica SRI",
		description:
			"Emite facturas electrónicas válidas ante el SRI de Ecuador. Firma digital, autorización automática y envío al cliente.",
	},
	{
		icon: "multi",
		title: "Multi-Consultorio y Roles",
		description:
			"Gestiona múltiples consultorios con usuarios, roles y permisos diferenciados por perfil desde una sola cuenta.",
	},
];

const iconPaths: Record<string, string> = {
	patients:
		"M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
	calendar:
		"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
	records:
		"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
	prescription:
		"M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
	billing:
		"M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z",
	multi:
		"M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
};
---

<section id="features" class="py-24 lg:py-32 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-6">
        <!-- Section header -->
        <div class="text-center max-w-2xl mx-auto mb-16">
            <div
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-semibold mb-6"
            >
                Funcionalidades
            </div>
            <h2
                class="text-3xl sm:text-4xl font-extrabold tracking-tight text-text mb-4"
            >
                Todo lo que necesitas para tu consulta
            </h2>
            <p class="text-lg text-text-muted">
                Herramientas diseñadas específicamente para profesionales de la
                salud en Ecuador que buscan eficiencia y cumplimiento normativo.
            </p>
        </div>

        <!-- Feature cards grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                features.map((feature) => (
                    <div class="group relative bg-surface rounded-2xl p-8 border border-border hover:border-primary/30 transition-all duration-300 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1">
                        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5 group-hover:bg-primary/15 transition-colors duration-300">
                            <svg
                                class="w-6 h-6 text-primary"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d={iconPaths[feature.icon]}
                                />
                            </svg>
                        </div>
                        <h3 class="text-lg font-bold text-text mb-2">
                            {feature.title}
                        </h3>
                        <p class="text-sm text-text-muted leading-relaxed">
                            {feature.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
