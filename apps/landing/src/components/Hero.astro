---

---

<section
    id="hero"
    class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden"
>
    <!-- Background gradient orbs -->
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div
        class="absolute top-40 right-0 w-[400px] h-[400px] bg-primary/8 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <!-- Text content -->
            <div class="flex flex-col gap-8">
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-semibold w-fit"
                >
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"
                    ></span>
                    Software Médico en la Nube
                </div>

                <h1
                    class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-text"
                >
                    Gestión clínica
                    <span
                        class="text-transparent bg-clip-text"
                        style="background-image: linear-gradient(to right, oklch(59.929% 0.0998 185.282), oklch(72% 0.10 183));"
                    >
                        simple y moderna
                    </span>
                </h1>

                <p class="text-lg text-text-muted max-w-xl leading-relaxed">
                    Administra pacientes, citas, expedientes clínicos y recetas
                    médicas desde una sola plataforma. Diseñado para médicos que
                    valoran su tiempo.
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a
                        href="#pricing"
                        id="hero-cta-primary"
                        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-base font-bold bg-primary text-primary-foreground hover:bg-primary-dark transition-all duration-300 shadow-xl shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-1"
                    >
                        Comenzar gratis
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                    <a
                        href="#features"
                        id="hero-cta-secondary"
                        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl text-base font-semibold text-text border-2 border-border hover:border-primary/30 hover:bg-primary/5 transition-all duration-300"
                    >
                        Ver funcionalidades
                    </a>
                </div>

                <!-- Trust badges -->
                <div class="flex items-center gap-6 pt-4">
                    <div
                        class="flex items-center gap-2 text-sm text-text-muted"
                    >
                        <svg
                            class="w-5 h-5 text-primary"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Sin tarjeta de crédito
                    </div>
                    <div
                        class="flex items-center gap-2 text-sm text-text-muted"
                    >
                        <svg
                            class="w-5 h-5 text-primary"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Configuración en minutos
                    </div>
                </div>
            </div>

            <!-- Dashboard preview -->
            <div class="relative hidden lg:block">
                <div
                    class="relative z-10 rounded-2xl overflow-hidden shadow-2xl shadow-primary/10 border border-border/50 transform perspective-1200 rotate-y-2 hover:rotate-y-0 transition-transform duration-700"
                >
                    <img
                        src="/hero-dashboard.png"
                        alt="Gentoo Dashboard — Gestión de pacientes y citas"
                        class="w-full h-auto"
                        loading="eager"
                    />
                </div>
                <!-- Floating decorative elements -->
                <div
                    class="absolute -bottom-6 -left-6 w-24 h-24 bg-primary/10 rounded-2xl -z-1 animate-pulse"
                >
                </div>
                <div
                    class="absolute -top-4 -right-4 w-16 h-16 bg-primary/15 rounded-xl -z-1 animate-pulse delay-1000"
                >
                </div>
            </div>
        </div>
    </div>
</section>
