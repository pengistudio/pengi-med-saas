---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Gentoo — Software Médico Inteligente',
	description = 'Gestiona pacientes, citas, expedientes clínicos y recetas desde una sola plataforma. Software médico moderno diseñado para clínicas y consultorios.',
} = Astro.props;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/gentoo.png" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="overflow-x-hidden">
		<slot />
	</body>
</html>
