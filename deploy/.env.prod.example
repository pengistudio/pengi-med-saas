# =============================================================
# Copia este archivo como .env.prod y completa los valores.
# NUNCA commitees .env.prod al repositorio.
# =============================================================

# --- Base de datos (DO Managed PostgreSQL) ---
DB_HOST=<DO_MANAGED_DB_HOST>
DB_PORT=25060
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=pengi_gentoo

# --- API ---
AUTH_KEY=<GENERA_CLAVE_ALEATORIA_32_CHARS>
AUTH_EXP=30
TZ=America/Guayaquil
GIN_MODE=release
PORT=8000
HTTPS_ENABLED=false

# --- SRI ---
SRI_SIGNER_SERVICE_URL=http://sri-xml-signer:9000
SRI_ENV=prod

# --- RabbitMQ ---
RABBITMQ_USER=<RABBITMQ_USER>
RABBITMQ_PASSWORD=<RABBITMQ_PASSWORD>

# --- Frontend (build args) ---
VITE_API_URL=https://api.tudominio.com/api/v1
