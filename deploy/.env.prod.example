# =============================================================
# Copia este archivo como .env.prod y completa los valores.
# NUNCA commitees .env.prod al repositorio.
# =============================================================

# --- Base de datos (DO Managed PostgreSQL) ---
DB_HOST=<DO_MANAGED_DB_HOST>
DB_PORT=25060
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=pengi_gentoo
DB_SSL_MODE=require

# --- API ---
AUTH_KEY=<GENERA_CLAVE_ALEATORIA_32_CHARS>
AUTH_EXP=30
TZ=America/Guayaquil
GIN_MODE=release
PORT=8000
HTTPS_ENABLED=false

# --- SRI ---
SRI_SIGNER_SERVICE_URL=http://sri-xml-signer:9000
SRI_ENV=prod

# --- RabbitMQ ---
RABBITMQ_USER=<RABBITMQ_USER>
RABBITMQ_PASSWORD=<RABBITMQ_PASSWORD>

# --- dLocal (pasarela de pagos) ---
DLOCAL_API_KEY=<DLOCAL_API_KEY>
DLOCAL_SECRET=<DLOCAL_SECRET>
DLOCAL_ENV=production
DLOCAL_NOTIFICATION_URL=https://api.gentoo.pengistudio.com/api/v1/webhooks/dlocal

# --- SMTP (verificación de email y notificaciones) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<EMAIL_REMITENTE>
SMTP_PASSWORD=<APP_PASSWORD_GMAIL>
SMTP_FROM=<EMAIL_REMITENTE>
SMTP_FROM_NAME=Gentoo
CONTACT_EMAIL=pengiservicios@gmail.com
CONTACT_RATE_LIMIT=3

# --- Google Calendar Integration ---
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
GOOGLE_REDIRECT_URL=https://api.gentoo.pengistudio.com/api/v1/integrations/google/callback
FRONTEND_URL=https://app.gentoo.pengistudio.com

# --- Frontend (build args) ---
VITE_API_URL=https://api.gentoo.pengistudio.com/api/v1
VITE_WEB_APP_URL=https://app.gentoo.pengistudio.com
PUBLIC_APP_URL=https://app.gentoo.pengistudio.com
